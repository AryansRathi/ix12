# ============================================
# Intrexx build
# ============================================
IX_VERSION=latest

# Optional: Specify the target to be built: rootful or rootless (default = rootful)
# INTREXX_TARGET=rootful

# Optional: Install additional software if your portal needs it
# INSTALL_IMAGEMAGICK=true # Default = true
# INSTALL_LIBREOFFICE=false # Default = false

# ----------- rootless ---------------------
# Optional: Define the user uid and gid to be used within the image.
# It only takes effect when INTREXX_TARGET=rootless (default = 1000:1000)
# INTREXX_USER_UID=1000
# INTREXX_USER_GID=1000

# ============================================
# Intrexx runtime
# ============================================
IX_PORTAL_NAME=portal
IX_DB_NAME=ixportal
# IX_DB_CREATE=true

# Optional: Define a directory on the host system where the portal directory should be created (only takes effect, when the compose.bind.yaml override is used).
# IX_PORTAL_DIR_HOST=./runtime/intrexx/org

# Optional: If a zipped portal export should be imported from services/intrexx/import, specify the name of the zip file
# IX_PORTAL_ZIP_NAME=myportal.zip

# ----------- standalone ---------------------
IX_PORTAL_BASE_URL=http://localhost:1337/
IX_WEBCONNECTOR_HOST_PORT=1337
IX_REST_HOST_PORT=8101
IX_ODATA_HOST_PORT=9090

# ----------- distributed --------------------
# IX_PORTAL_BASE_URL=http://ix12-intrexx-in-docker.localhost:1337/
# IX_WEBCONNECTOR_HOST_PORT=1338-1340
# IX_REST_HOST_PORT=8101-8103
# IX_ODATA_HOST_PORT=9090-9092
# IX_DEPLOY_MODE=replicated
# IX_DEPLOY_REPLICATIONS=3
# IX_DISTRIBUTED_NODELIST="ix12-intrexx-in-docker-intrexx-1,ix12-intrexx-in-docker-intrexx-2,ix12-intrexx-in-docker-intrexx-3"

# ============================================
# PostgreSQL
# ============================================
PG_VERSION=18-alpine
PG_PASSWORD=postgres
PG_USER=postgres

# ============================================
# Solr
# ============================================
# https://github.com/docker-solr/docker-solr/blob/master/Docker-FAQ.md
SOLR_VERSION=9.10.1
SOLR_OPTS="-XX:-UseLargePages -Dsolr.jetty.request.header.size=65535"
SOLR_USER=solr
SOLR_PASSWORD=SolrRocks
SOLR_PATH=""

# ============================================
# Zookeeper
# ============================================
ZOOKEEPER_VERSION=3.9.4

# ============================================
# Intrexx Admin API build
# ============================================
# Optional: Specify the target to be built: rootful or rootless (default = rootful)
# ADMIN_API_TARGET=${INTREXX_TARGET}

# ----------- rootless ---------------------
# Optional: Define the user uid and gid to be used within the image.
# It only takes effect when ADMIN_API_TARGET=rootless (default = 1000:1000)
# ADMIN_API_USER_UID=${INTREXX_USER_UID}
# ADMIN_API_USE_GID=${INTREXX_USER_GID}

# ============================================
# Intrexx Admin API runtime
# ============================================
# ADMIN_API_HOST_PORT=4242
# PORTAL_API_PORT=8101
# PORTAL_HOST=intrexx
# PORTAL_NAME=${IX_PORTAL_NAME}
# PORTAL_API_SCHEME=https
# PORTAL_ADMIN_USER=Administrator
# PORTAL_ADMIN_PW=NONE
# IAA_USER=iaa-admin
# IAA_PW=P4$$w0rD
# IAA_DEBUG_MODE=false
# IAA_SECRET=changeit
# IAA_USE_SSL=true
# IAA_LICENSE=NONE

# ----------- self signed certificate --------
# CACERTS_SAN_LIST="dns:www.example.org ip:198.51.100.12 ip:127.0.0.1"

# ----------- provide custom keystore --------
# Optional: If a custom keystore should be used, place it in runtime/admin-api/cfg and specify the name and the password of the keystore file
# CUSTOM_CACERTS_FILE=cacerts
# CUSTOM_CACERTS_PW=changeit

# ============================================
# Traefik
# ============================================
# ----------- distributed --------------------
# TRAEFIK_VERSION=v3.6
