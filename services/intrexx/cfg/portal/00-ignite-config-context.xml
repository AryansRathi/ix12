<?xml version="1.0" encoding="UTF-8"?>
<beans
		xmlns="http://www.springframework.org/schema/beans"
		xmlns:context="http://www.springframework.org/schema/context"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">

	<!-- NOTE: Do not edit this file. Custom Spring beans should reside in their own files. -->

	<bean id="igniteCfg" class="org.apache.ignite.configuration.IgniteConfiguration">
		<property name="igniteInstanceName" value="IntrexxDataGrid"/>

		<!-- Set this value to a number n > 0, to write health metrics of each node to the log every n miliseconds -->
		<property name="metricsLogFrequency" value="0"/>

		<!-- As to overcome data corruption due to eventual server failures or network segmentations, the default cache
		template, and the atomicConfiguration template should be replicated, or partitioned with a backup >= 2.
		Otherwise the dataGrid wont start. This does not affect specific caches, however think twice before configuring
		it so. Sets are per Intrexx default replicated and collocated. -->
		<property name="cacheConfiguration">
			<bean class="org.apache.ignite.configuration.CacheConfiguration">
				<property name="name" value="*"/>
				<property name="atomicityMode" value="ATOMIC"/>
				<property name="cacheMode" value="REPLICATED"/>
				<!-- Optimize performance by forcing cache to return the a reference to the instance instead of creating a copy.
				 https://apacheignite.readme.io/docs/performance-tips#do-not-copy-value-on-read -->
				<property name="copyOnRead" value="false"/>
				<!-- Uncomment this to enable data grid topology validation.
					 See https://apacheignite.readme.io/docs/topology-validation -->
				<!--
				<property name="topologyValidator">
					<bean class="de.uplanet.lucy.server.distributed.cloud.datagrid.ignite.GridSizeTopologyValidator">
						<constructor-arg type="java.lang.Integer" value="2"/>
					</bean>
				</property>
				-->
			</bean>
		</property>

		<property name="atomicConfiguration">
			<bean class="org.apache.ignite.configuration.AtomicConfiguration">
				<property name="cacheMode" value="REPLICATED"/>
			</bean>
		</property>

		<!-- Set to true to enable ignite-aware class loading, default is false. -->
		<!-- property name="peerClassLoadingEnabled" value="false" / -->

		<!-- Define work directory. -->
		<!-- property name="workDirectory" value="/tmp/ignite" / -->

		<!-- Explicitly configure TCP discovery SPI to provide list of initial nodes. -->
		<property name="discoverySpi">
			<bean class="org.apache.ignite.spi.discovery.tcp.TcpDiscoverySpi">
				<property name="ipFinder">
					<!-- Shared filesystem IP finder. Stores member ip adress on filesystem on node startup. -->
					<bean class="org.apache.ignite.spi.discovery.tcp.ipfinder.sharedfs.TcpDiscoverySharedFsIpFinder">
						<property name="path" value="/opt/intrexx/org/portal/cluster_nodes"/>
					</bean>
				</property>
			</bean>
		</property>
	</bean>

	<!-- AWS credentials for AWS ELB IP finder. Provide your access key ID and secret access key. -->
	<!-- bean id="aws.creds" class="com.amazonaws.auth.BasicAWSCredentials">
		<constructor-arg value="YOUR_ACCESS_KEY_ID" />
		<constructor-arg value="YOUR_SECRET_ACCESS_KEY" />
	</bean -->

</beans>
